{
  "family": "fica-compliance-worker-task-prod",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::026465780614:role/ocr-rebuild-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::026465780614:role/ocr-rebuild-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "fica_compliance",
      "image": "026465780614.dkr.ecr.us-east-1.amazonaws.com/fica-compliance-worker:phase5",
      "essential": true,
      "command": [
        "python",
        "-m",
        "services.fica_compliance.worker"
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fica-compliance-worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
