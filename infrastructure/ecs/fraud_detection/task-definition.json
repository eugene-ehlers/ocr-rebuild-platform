{
  "family": "fraud-detection-worker-task-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/ocr-rebuild-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/ocr-rebuild-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "fraud-detection-worker",
      "image": "ACCOUNT.dkr.ecr.REGION.amazonaws.com/fraud-detection-worker:latest",
      "essential": true,
      "environment": [
        { "name": "FRAUD_INPUT", "value": "/tmp/fraud_input.json" },
        { "name": "FRAUD_OUTPUT", "value": "/tmp/fraud_output.json" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fraud-detection-worker",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
