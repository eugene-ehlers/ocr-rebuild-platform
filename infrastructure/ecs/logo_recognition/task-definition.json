{
  "family": "logo-recognition-worker-task-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::026465780614:role/ocr-rebuild-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::026465780614:role/ocr-rebuild-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "logo-recognition-worker",
      "image": "026465780614.dkr.ecr.us-east-1.amazonaws.com/logo-recognition-worker:phase5-logo-recognition-20260319-5f83c1f",
      "essential": true,
      "environment": [
        {
          "name": "LOGO_INPUT",
          "value": "/tmp/logo_input.json"
        },
        {
          "name": "LOGO_OUTPUT",
          "value": "/tmp/logo_output.json"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/logo-recognition-worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}