{
  "family": "ocr-worker-task-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/ocr-rebuild-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/ocr-rebuild-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "ocr-worker",
      "image": "ACCOUNT.dkr.ecr.REGION.amazonaws.com/ocr-worker:latest",
      "essential": true,
      "environment": [
        { "name": "PROCESSED_BUCKET", "value": "ocr-rebuild-processed-bucket" },
        { "name": "RESULT_BUCKET", "value": "ocr-rebuild-results-bucket" },
        { "name": "OCR_INPUT", "value": "/tmp/ocr_input.json" },
        { "name": "OCR_OUTPUT", "value": "/tmp/ocr_output.json" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ocr-worker",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
