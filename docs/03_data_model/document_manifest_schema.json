{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "document_manifest_schema",
  "description": "Controlled baseline schema for OCR processing manifests. Hardened from Phase 4 build-plan Step 3 and Phase 3 schema audit. Expanded to include explicit requested service selection and service lifecycle status tracking for modular pipeline execution.",
  "type": "object",
  "properties": {
    "manifest_id": {
      "type": "string",
      "description": "Unique identifier for the processing manifest."
    },
    "creation_timestamp": {
      "type": "string",
      "description": "Manifest creation timestamp in ISO 8601 format."
    },
    "source_batch_uri": {
      "type": "string",
      "description": "Location of the source document batch."
    },
    "documents": {
      "type": "array",
      "description": "Documents included in the processing batch.",
      "items": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Reference to canonical document_id."
          },
          "source_uri": {
            "type": "string",
            "description": "Original document location."
          },
          "expected_document_type": {
            "type": "string",
            "description": "Expected or classified document type.",
            "default": "UNKNOWN"
          }
        },
        "required": [
          "document_id"
        ],
        "additionalProperties": true
      }
    },
    "processing_parameters": {
      "type": "object",
      "description": "Batch-level processing configuration.",
      "default": {}
    },
    "requested_services": {
      "type": "object",
      "description": "Requested service selection for this manifest execution scope.",
      "properties": {
        "ocr": {
          "type": "boolean",
          "default": true
        },
        "table_extraction": {
          "type": "boolean",
          "default": false
        },
        "logo_recognition": {
          "type": "boolean",
          "default": false
        },
        "fraud_detection": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": true,
      "default": {
        "ocr": true,
        "table_extraction": false,
        "logo_recognition": false,
        "fraud_detection": false
      }
    },
    "pipeline_status": {
      "type": "string",
      "description": "Overall manifest processing state.",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed",
        "partial",
        "UNKNOWN"
      ],
      "default": "UNKNOWN"
    },
    "retry_count": {
      "type": "integer",
      "description": "Retry count for the manifest or current processing scope.",
      "minimum": 0,
      "default": 0
    },
    "last_updated": {
      "type": "string",
      "description": "Last manifest update timestamp in ISO 8601 format."
    },
    "partial_execution_flags": {
      "type": "object",
      "description": "Flags indicating page-level or pipeline-level partial execution states.",
      "default": {}
    },
    "service_status": {
      "type": "object",
      "description": "Lifecycle status of mandatory and optional pipeline services for this manifest execution scope.",
      "properties": {
        "ocr": {
          "type": "string",
          "enum": [
            "requested",
            "not_requested",
            "skipped",
            "processing",
            "completed",
            "failed",
            "partial"
          ],
          "default": "requested"
        },
        "table_extraction": {
          "type": "string",
          "enum": [
            "requested",
            "not_requested",
            "skipped",
            "processing",
            "completed",
            "failed",
            "partial"
          ],
          "default": "not_requested"
        },
        "logo_recognition": {
          "type": "string",
          "enum": [
            "requested",
            "not_requested",
            "skipped",
            "processing",
            "completed",
            "failed",
            "partial"
          ],
          "default": "not_requested"
        },
        "fraud_detection": {
          "type": "string",
          "enum": [
            "requested",
            "not_requested",
            "skipped",
            "processing",
            "completed",
            "failed",
            "partial"
          ],
          "default": "not_requested"
        }
      },
      "additionalProperties": true,
      "default": {
        "ocr": "requested",
        "table_extraction": "not_requested",
        "logo_recognition": "not_requested",
        "fraud_detection": "not_requested"
      }
    },
    "client_notification": {
      "type": "object",
      "description": "Notification status and details for client-facing communication.",
      "properties": {
        "required": {
          "type": "boolean",
          "default": false
        },
        "status": {
          "type": "string",
          "default": "not_required"
        },
        "message": {
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": true,
      "default": {
        "required": false,
        "status": "not_required",
        "message": ""
      }
    },
    "pipeline_history": {
      "type": "array",
      "description": "Chronological history of pipeline actions, stages, engines, and status transitions.",
      "items": {
        "type": "object",
        "properties": {
          "stage": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "engine_name": {
            "type": "string"
          },
          "engine_version": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "stage",
          "status",
          "timestamp"
        ],
        "additionalProperties": true
      },
      "default": []
    }
  },
  "required": [
    "manifest_id"
  ],
  "additionalProperties": true
}
