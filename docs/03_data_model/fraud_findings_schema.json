{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "fraud_findings_schema",
  "description": "Controlled baseline schema for fraud detection outputs. Hardened from the Phase 3 schema audit. This schema defines the minimum page-level fraud enrichment payload expected from the fraud detection stage.",
  "type": "object",
  "properties": {
    "document_id": {
      "type": "string",
      "description": "Unique document identifier."
    },
    "page_number": {
      "type": "integer",
      "description": "Page number associated with the fraud analysis result.",
      "minimum": 1
    },
    "fraud_flags": {
      "type": "array",
      "description": "Fraud or tampering indicators detected for the page.",
      "items": {
        "type": "object",
        "properties": {
          "flag_type": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical",
              "UNKNOWN"
            ],
            "default": "UNKNOWN"
          },
          "confidence_score": {
            "type": "number"
          },
          "description": {
            "type": "string"
          },
          "evidence": {
            "type": "object",
            "description": "Optional structured evidence supporting the fraud flag.",
            "default": {}
          }
        },
        "required": [
          "flag_type"
        ],
        "additionalProperties": true
      },
      "default": []
    },
    "metadata": {
      "type": "object",
      "description": "Stage-level metadata including execution notes, engine traceability, and partial processing indicators.",
      "properties": {
        "stage": {
          "type": "string",
          "default": "fraud_detection"
        },
        "engine_name": {
          "type": "string"
        },
        "engine_version": {
          "type": "string"
        },
        "partial_execution": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string",
          "default": ""
        }
      },
      "additionalProperties": true,
      "default": {
        "stage": "fraud_detection",
        "partial_execution": false,
        "notes": ""
      }
    }
  },
  "required": [
    "document_id",
    "page_number",
    "fraud_flags"
  ],
  "additionalProperties": true
}
